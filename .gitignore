# Godot 4 ignores
.godot/
.import/
*.import
export.cfg
*.translation

# Release build artifacts (produced by the export workflow / local exports)
/build/

# Mono / .NET (unused now, here for later)
.mono/
data_*/
mono_crash.*

# Test framework (GUT) is vendored at CI/dev time, not committed — see test/README.md
/addons/gut/

# Test artifacts
test_results.xml
import.log

# OS / editor cruft
.DS_Store
Thumbs.db

# Quarto documentation site (website/) — build output and cache are generated
.quarto/
website/.quarto/
website/_site/
/_freeze/
website/_freeze/
# Demo clips are recorded by CI (publish-site.yml) into website/media/, not committed
website/media/*.mp4
website/media/*.jpg
